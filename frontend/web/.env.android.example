# Copy to .env.android (gitignored) and fill in your production server URL.
# This is required for the Capacitor/Android build — relative /api/... paths
# don't resolve inside the Android WebView.
VITE_API_BASE_URL=https://your-server.com

# GlitchTip / Sentry DSN for frontend error + log reporting. Optional —
# leave blank to disable Sentry in this build. Same DSN as backend; the
# Service dropdown in GlitchTip Logs distinguishes frontend from backend
# via service.name attribute (set in src/observability.js).
VITE_SENTRY_DSN=
