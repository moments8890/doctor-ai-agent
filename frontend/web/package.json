{
  "name": "doctor-ai-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:stable": "VITE_NO_HMR=1 vite",
    "build": "vite build",
    "build:android": "vite build --mode android",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test && python3 scripts/generate-test-report.py",
    "test:e2e:report": "python3 scripts/generate-test-report.py",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@capacitor/core": "^7.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.0.1",
    "@mui/material": "^7.0.1",
    "@tanstack/react-query": "^5.96.2",
    "antd-mobile": "^5.42.3",
    "antd-mobile-icons": "^0.3.0",
    "framer-motion": "^12.38.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.3.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^27.0.1",
    "typescript": "^6.0.2",
    "vite": "^6.2.2",
    "vitest": "^3.2.4"
  }
}
