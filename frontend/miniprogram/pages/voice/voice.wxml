<view class="container">
  <!-- Processing -->
  <view wx:if="{{processing}}" class="center-col">
    <view class="spinner" />
    <text class="hint">识别中...</text>
  </view>

  <!-- Error -->
  <view wx:elif="{{error}}" class="center-col">
    <text class="error">{{error}}</text>
    <view class="link" bindtap="onRetry">重试</view>
    <view class="link muted" bindtap="onBack">返回</view>
  </view>

  <!-- Recording -->
  <view wx:else class="center-col">
    <view class="wave-row" wx:if="{{recording}}">
      <view class="bar" style="animation-delay:0s" />
      <view class="bar" style="animation-delay:0.15s" />
      <view class="bar" style="animation-delay:0.3s" />
      <view class="bar" style="animation-delay:0.15s" />
      <view class="bar" style="animation-delay:0s" />
    </view>

    <text class="timer" wx:if="{{recording}}">{{timerText}}</text>
    <text class="hint" wx:if="{{recording}}">正在录音...</text>
    <text class="hint" wx:if="{{!recording}}">准备录音</text>

    <view class="btn-row">
      <view class="btn cancel" bindtap="onCancel">取消</view>
      <view class="btn primary" wx:if="{{recording}}" bindtap="onStop">完成</view>
    </view>
  </view>
</view>
