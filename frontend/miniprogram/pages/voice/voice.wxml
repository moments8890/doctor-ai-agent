<view class="container">
  <!-- Processing -->
  <view wx:if="{{processing}}" class="center-col">
    <view class="spinner" />
    <text class="hint-text">识别中...</text>
  </view>

  <!-- Error -->
  <view wx:elif="{{error}}" class="center-col">
    <text class="error-text">{{error}}</text>
    <view class="btn btn-secondary" bindtap="onCancel">返回</view>
  </view>

  <!-- Recording / Ready -->
  <view wx:else class="center-col">
    <!-- Timer + wave animation while recording -->
    <view wx:if="{{recording}}" class="wave-container">
      <view class="wave-bar" style="animation-delay:0s" />
      <view class="wave-bar" style="animation-delay:0.15s" />
      <view class="wave-bar" style="animation-delay:0.3s" />
      <view class="wave-bar" style="animation-delay:0.15s" />
      <view class="wave-bar" style="animation-delay:0s" />
    </view>
    <text wx:if="{{recording}}" class="timer">{{timerText}}</text>

    <!-- Big mic button -->
    <view
      class="mic-btn {{recording ? (cancelled ? 'mic-cancel' : 'mic-active') : ''}}"
      bindtouchstart="onTouchStart"
      bindtouchend="onTouchEnd"
      bindtouchmove="onTouchMove"
    >
      <text class="mic-icon">🎤</text>
    </view>

    <text class="hint-text">
      {{recording ? (cancelled ? '松开取消' : '松开发送') : '按住录音'}}
    </text>
    <text wx:if="{{recording}}" class="cancel-hint">上滑取消</text>

    <!-- Cancel link -->
    <view class="btn btn-secondary" bindtap="onCancel">取消</view>
  </view>
</view>
