/* Loading overlay */
.loading {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f3f7f8;
  z-index: 10;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e2e8f0;
  border-top-color: #2563eb;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #64748b;
}

/* Notification permission prompt */
.permission-prompt {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #eff6ff 0%, #e0f2fe 100%);
  z-index: 20;
  padding: 48rpx;
}

.permission-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 64rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.08);
  width: 100%;
}

.permission-icon {
  font-size: 80rpx;
  margin-bottom: 32rpx;
}

.permission-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e3a5f;
  margin-bottom: 20rpx;
}

.permission-desc {
  font-size: 28rpx;
  color: #64748b;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 56rpx;
}

.permission-btn {
  width: 100%;
  background: #2563eb;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  padding: 28rpx 0;
  border: none;
}

.permission-btn::after {
  border: none;
}

/* Error view */
.error-view {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f8fafc;
  padding: 48rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 30rpx;
  color: #64748b;
  text-align: center;
  margin-bottom: 40rpx;
}

.retry-btn {
  background: #2563eb;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  padding: 24rpx 80rpx;
  border: none;
}

.retry-btn::after {
  border: none;
}
