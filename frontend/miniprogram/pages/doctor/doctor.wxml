<!-- Notification permission prompt — shown once before the WebView loads.
     The "开始使用" button tap satisfies WeChat's TAP gesture requirement
     for wx.requestSubscribeMessage. -->
<view wx:if="{{showPermissionPrompt}}" class="permission-prompt">
  <view class="permission-card">
    <view class="permission-icon">🔔</view>
    <view class="permission-title">开启消息提醒</view>
    <view class="permission-desc">开启后，当有新任务或患者消息时，您将收到微信通知。</view>
    <button class="permission-btn" bindtap="onEnterTap">开始使用</button>
  </view>
</view>

<!-- Loading spinner shown while the WebView is fetching the dashboard. -->
<view wx:if="{{loading && url}}" class="loading">
  <view class="loading-spinner" />
  <text class="loading-text">加载中…</text>
</view>

<!-- Main dashboard WebView. -->
<web-view wx:if="{{url && !showPermissionPrompt}}" src="{{url}}" bindmessage="onMessage" bindload="onWebViewLoad" />
