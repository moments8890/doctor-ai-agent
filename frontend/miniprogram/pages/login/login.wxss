.page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #f0f7ff 0%, #e8f5f0 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

.card {
  width: 100%;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(15, 23, 42, 0.10);
}

/* Brand */
.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}
.brand-icon {
  font-size: 72rpx;
  margin-bottom: 12rpx;
}
.brand-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 2rpx;
}
.brand-sub {
  font-size: 26rpx;
  color: #64748b;
  margin-top: 6rpx;
}

/* Tabs */
.tabs {
  display: flex;
  background: #f1f5f9;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 32rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #64748b;
  border-radius: 12rpx;
  transition: all 0.2s;
}
.tab-active {
  background: #ffffff;
  color: #0f172a;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* Input */
.input {
  height: 88rpx;
  border: 1.5px solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #0f172a;
  background: #f8fafc;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  width: 100%;
}

/* WeChat hint */
.wechat-hint {
  font-size: 26rpx;
  color: #64748b;
  text-align: center;
  margin-bottom: 28rpx;
  line-height: 1.6;
}

/* Buttons */
.btn {
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-primary {
  background: #2563eb;
  color: #ffffff;
}
.btn-wechat {
  background: #07c160;
  color: #ffffff;
}

/* Auto-login loading overlay */
.loading-overlay {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #f0f7ff 0%, #e8f5f0 100%);
}
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e2e8f0;
  border-top-color: #2563eb;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.loading-hint {
  font-size: 28rpx;
  color: #64748b;
}

/* Error */
.error {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #fef2f2;
  border-radius: 12rpx;
  color: #dc2626;
  font-size: 26rpx;
  text-align: center;
}
