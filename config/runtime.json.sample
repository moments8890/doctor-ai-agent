{
  "format": "doctor-ai-agent.runtime-config.v2",
  "description": "Runtime configuration catalog with grouped settings and inline descriptions.",
  "description_zh": "运行时配置目录，按分类组织并包含每项配置说明。",
  "categories": {
    "llm": {
      "description": "LLM provider routing and model selection.",
      "description_zh": "LLM 提供商路由与模型选择。",
      "settings": {
        "ROUTING_LLM": {
          "value": "ollama",
          "description": "Provider for intent/tool routing. Note: Ollama is LAN/local LLM (can be slower); DeepSeek is online LLM (billed).",
          "description_zh": "意图/工具路由使用的提供商。说明：Ollama 通常是局域网/本地 LLM（可能较慢）；DeepSeek 是在线 LLM（按量计费）。",
          "options": [
            "ollama",
            "deepseek",
            "groq",
            "gemini",
            "openai"
          ]
        },
        "STRUCTURING_LLM": {
          "value": "ollama",
          "description": "Provider for medical record structuring. Note: Ollama is LAN/local LLM (can be slower); DeepSeek is online LLM (billed).",
          "description_zh": "病历结构化使用的提供商。说明：Ollama 通常是局域网/本地 LLM（可能较慢）；DeepSeek 是在线 LLM（按量计费）。",
          "options": [
            "ollama",
            "deepseek",
            "groq",
            "gemini",
            "openai"
          ]
        },
        "INTENT_PROVIDER": {
          "value": "local",
          "description": "Intent mode: local or model-driven.",
          "description_zh": "意图模式：local 或 model-driven。",
          "options": [
            "local",
            "model-driven"
          ]
        },
        "LLM_PROVIDER_STRICT_MODE": {
          "value": "true",
          "description": "When true, use selected provider only and never fallback to others.",
          "description_zh": "为 true 时仅使用所选提供商，不会自动回退到其它提供商。",
          "options": [
            "true",
            "false"
          ]
