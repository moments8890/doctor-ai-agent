    "automation": {
      "description": "Clinical automation and scheduler behavior.",
      "description_zh": "临床自动化与调度行为。",
      "settings": {
        "AUTO_FOLLOWUP_TASKS_ENABLED": {
          "value": false,
          "description": "Enable auto follow-up task generation.",
          "description_zh": "是否开启自动生成随访任务。"
        },
        "TASK_SCHEDULER_INTERVAL_MINUTES": {
          "value": 1,
          "description": "Interval mode cadence in minutes.",
          "description_zh": "interval 模式的分钟间隔。"
        },
        "TASK_NOTIFY_RETRY_COUNT": {
          "value": 3,
          "description": "Retry attempts for notification sends.",
          "description_zh": "通知失败重试次数。"
        },
        "TASK_NOTIFY_RETRY_DELAY_SECONDS": {
          "value": 1,
          "description": "Delay between retries.",
          "description_zh": "重试间隔秒数。"
        },
        "KNOWLEDGE_CANDIDATE_LIMIT": {
          "value": 30,
          "description": "How many knowledge items to scan per doctor before ranking.",
          "description_zh": "每次检索医生知识库时参与排序的候选条数。"
        },
        "KNOWLEDGE_MAX_ITEMS": {
          "value": 3,
          "description": "Maximum number of knowledge snippets injected into routing prompt.",
          "description_zh": "注入路由 prompt 的知识片段最大条数。"
        },
        "KNOWLEDGE_MAX_CHARS": {
          "value": 1200,
          "description": "Total character budget for injected knowledge prompt section.",
          "description_zh": "注入知识片段的总字符预算上限。"
        },
        "KNOWLEDGE_MAX_ITEM_CHARS": {
          "value": 320,
          "description": "Per-knowledge-item character cap before prompt injection.",
          "description_zh": "单条知识片段注入前的字符截断上限。"
        },
        "KNOWLEDGE_AUTO_LEARN_ENABLED": {
          "value": true,
          "description": "Enable automatic knowledge capture from successful clinical turns.",
          "description_zh": "是否开启从临床对话自动沉淀知识。",
          "options": [
            "true",
            "false"
          ]
        },
        "KNOWLEDGE_AUTO_MAX_NEW_PER_TURN": {
          "value": 1,
          "description": "Maximum auto-learned snippets inserted per chat turn.",
          "description_zh": "每轮对话最多自动新增的知识条数。"
        },
        "KNOWLEDGE_AUTO_MIN_TEXT_CHARS": {
          "value": 8,
          "description": "Minimum user-text length to consider for auto-learning.",
          "description_zh": "触发自动沉淀时，医生输入的最小长度阈值。"
        }
      }
