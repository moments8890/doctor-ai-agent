{
  "schema_version": 2,
  "id": "gm_interview_summary",
  "scenario_type": "doctor_chat",
  "title": "Interview summary style record",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "李雷"
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "李雷门诊记录：阵发性心悸三天，伴轻微胸闷，无晕厥。诱因不明显。无特殊既往史和家族史。建议完善24小时动态心电图Holter。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "李雷"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.interview_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
