{
  "schema_version": 2,
  "id": "gastro_liver_cirrhosis",
  "scenario_type": "doctor_chat",
  "title": "Specialty: gastroenterology liver cirrhosis with Child-Pugh",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "郑国强",
    "gender": "男",
    "age": 55
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者郑国强，男55岁，消化内科。乙肝后肝硬化Child-Pugh B级，腹水中量，ALT 86 U/L，AST 102 U/L，ALB 28 g/L，予利尿及保肝治疗。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "郑国强"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.interview_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
