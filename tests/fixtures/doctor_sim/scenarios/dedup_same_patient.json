{
  "schema_version": 2,
  "id": "dedup_same_patient",
  "scenario_type": "doctor_chat",
  "title": "Duplicate create should reuse the same patient",
  "tags": [
    "regression",
    "dedup"
  ],
  "patient": {
    "name": "周宁",
    "gender": "女",
    "age": 48
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者周宁，女48岁，门诊。"
      },
      {
        "actor": "doctor",
        "text": "再建一次同一位患者周宁，女48岁，门诊。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "周宁"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
