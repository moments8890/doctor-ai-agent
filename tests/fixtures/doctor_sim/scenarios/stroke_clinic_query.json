{
  "schema_version": 2,
  "id": "stroke_clinic_query",
  "scenario_type": "doctor_chat",
  "title": "Create then query history: stroke clinic",
  "tags": [
    "regression",
    "query_history"
  ],
  "patient": {
    "name": "张桂兰",
    "gender": "女",
    "age": 72
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者张桂兰，女72岁，卒中门诊。右侧肢体麻木反复3天，既往TIA史，ABCD2 5分，颈动脉超声示右侧斑块，氯吡格雷75mg qd。"
      },
      {
        "actor": "doctor",
        "text": "查张桂兰最近病历"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "张桂兰"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.interview_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
