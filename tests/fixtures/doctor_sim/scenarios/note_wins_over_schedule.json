{
  "schema_version": 2,
  "id": "note_wins_over_schedule",
  "scenario_type": "doctor_chat",
  "title": "Compound: clinical note wins over scheduling hint",
  "tags": [
    "regression",
    "compound_priority"
  ],
  "patient": {
    "name": "吴海燕",
    "gender": "女",
    "age": 58
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者吴海燕，女58岁，心内门诊。反复胸闷两周，活动后加重，心电图ST段压低，三个月后随访。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "吴海燕"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.interview_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
