{
  "case_id": "MVP-ACC-010",
  "title": "Duplicate create should reuse the same patient",
  "group": "dedup",
  "chatlog": [
    {
      "speaker": "doctor",
      "text": "创建患者周宁，女48岁，门诊。",
      "assert": {
        "tools_include": [
          "create_record"
        ],
        "llm_calls": 3
      }
    },
    {
      "speaker": "doctor",
      "text": "确认",
      "assert": {
        "tools_include": [],
        "llm_calls": 0
      }
    },
    {
      "speaker": "doctor",
      "text": "再建一次同一位患者周宁，女48岁，门诊。",
      "assert": {
        "tools_include": [
          "create_record"
        ],
        "llm_calls": 3
      }
    },
    {
      "speaker": "doctor",
      "text": "确认",
      "assert": {
        "tools_include": [],
        "llm_calls": 0
      }
    }
  ],
  "expectations": {
    "must_not_timeout": true,
    "expected_patient_name": "周宁",
    "expected_patient_count": 1,
    "expect_patient_dedup": true,
    "expected_table_min_counts_by_doctor": {
      "patients": 1
    }
  }
}
