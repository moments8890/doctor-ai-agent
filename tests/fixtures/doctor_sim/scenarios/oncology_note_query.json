{
  "schema_version": 2,
  "id": "oncology_note_query",
  "scenario_type": "doctor_chat",
  "title": "Create then query history: oncology note retrieval",
  "tags": [
    "regression",
    "query_history"
  ],
  "patient": {
    "name": "何志远",
    "gender": "男",
    "age": 58
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者何志远，男58岁，肿瘤科。结肠癌化疗后第5天，ANC 0.8，Hb 92，PLT 76，体温38.2度，考虑G-CSF并经验性抗感染。"
      },
      {
        "actor": "doctor",
        "text": "查何志远最近记录"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "何志远"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.interview_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
