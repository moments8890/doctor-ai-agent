{
  "schema_version": 2,
  "id": "record_plus_task_reminder",
  "scenario_type": "doctor_chat",
  "title": "Compound record + task: record and reminder for existing patient",
  "tags": [
    "regression",
    "compound_record_task"
  ],
  "patient": {
    "name": "张三",
    "gender": "男",
    "age": 45
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者张三，男45岁，内科门诊。高血压病史3年。"
      },
      {
        "actor": "doctor",
        "text": "给张三补充胸闷，明天提醒复查"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "张三"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.intake_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
