{
  "schema_version": 2,
  "id": "query_no_write_side_effects",
  "scenario_type": "doctor_chat",
  "title": "Query only: no write side effects",
  "tags": [
    "regression",
    "query_only"
  ],
  "patient": {
    "name": "张三",
    "gender": "男",
    "age": 45
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者张三，男45岁，内科门诊。高血压病史3年，BP 145/92。"
      },
      {
        "actor": "doctor",
        "text": "查张三最近病历"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "张三"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.intake_sessions.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.medical_records.count",
        "matcher": "max",
        "expected": 1
      }
    ]
  }
}
