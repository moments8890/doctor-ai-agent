{
  "schema_version": 2,
  "id": "ds_lung_nodule_interview",
  "scenario_type": "doctor_chat",
  "title": "Lung nodule interview summary",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "赵伟",
    "gender": "男",
    "age": 45
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "新患者赵伟，男，45岁。体检发现肺结节，右肺上叶8mm磨玻璃结节，无症状，不吸烟，父亲肺癌。本次CT提示考虑早期肺癌可能，建议3个月复查。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "赵伟"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.interview_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
