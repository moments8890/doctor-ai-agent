{
  "schema_version": 2,
  "id": "help_request",
  "scenario_type": "doctor_chat",
  "title": "Edge case: help request should show capabilities",
  "tags": [
    "regression",
    "safety"
  ],
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "帮助"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.count",
        "matcher": "max",
        "expected": 0
      },
      {
        "target": "db.medical_records.count",
        "matcher": "max",
        "expected": 0
      }
    ]
  }
}
