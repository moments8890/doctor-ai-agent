{
  "schema_version": 2,
  "id": "correct_insulin_dose",
  "scenario_type": "doctor_chat",
  "title": "Create then correct latest record: insulin dose correction",
  "tags": [
    "regression",
    "update_record"
  ],
  "patient": {
    "name": "孙雅宁",
    "gender": "女",
    "age": 59
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者孙雅宁，女59岁，内分泌门诊。2型糖尿病伴CKD G3b，eGFR 38 mL/min/1.73m2，UACR 312 mg/g，预混30R早18U晚14U。"
      },
      {
        "actor": "doctor",
        "text": "更正孙雅宁刚才那条病历：早晨胰岛素不是18U，是16U。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "孙雅宁"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.interview_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
