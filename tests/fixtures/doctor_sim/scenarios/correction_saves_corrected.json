{
  "schema_version": 2,
  "id": "correction_saves_corrected",
  "scenario_type": "doctor_chat",
  "title": "Same-turn correction: should save corrected content only",
  "tags": [
    "regression",
    "correction"
  ],
  "patient": {
    "name": "王芳"
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者王芳，胸痛，说错了，头痛"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "王芳"
      }
    ]
  }
}
