{
  "schema_version": 2,
  "id": "create_with_clinical_content",
  "scenario_type": "doctor_chat",
  "title": "Compound: create patient with clinical content appends record",
  "tags": [
    "regression",
    "compound_priority"
  ],
  "patient": {
    "name": "陈伟强",
    "gender": "男",
    "age": 42
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "新患者陈伟强，男42岁，头痛三天伴恶心呕吐，血压165/100，CT未见出血。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "陈伟强"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.intake_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
