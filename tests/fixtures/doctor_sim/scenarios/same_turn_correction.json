{
  "schema_version": 2,
  "id": "same_turn_correction",
  "scenario_type": "doctor_chat",
  "title": "Same-turn correction: correction rewrites unsaved payload",
  "tags": [
    "regression",
    "correction"
  ],
  "patient": {
    "name": "马建国",
    "gender": "男",
    "age": 50
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者马建国，男50岁，心内门诊。胸痛1小时，说错了，应该是胸闷2天。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "马建国"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.interview_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
