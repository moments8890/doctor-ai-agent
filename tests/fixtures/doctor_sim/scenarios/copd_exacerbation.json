{
  "schema_version": 2,
  "id": "copd_exacerbation",
  "scenario_type": "doctor_chat",
  "title": "Compound create-save: COPD exacerbation",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "周明哲",
    "gender": "男",
    "age": 72
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者周明哲，男72岁，呼吸门诊。COPD急性加重3天，SpO2 88%，RR 28次/分，双肺哮鸣音，WBC 12.4，CRP 38，予布地奈德雾化和哌拉西林他唑巴坦。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "周明哲"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.intake_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
