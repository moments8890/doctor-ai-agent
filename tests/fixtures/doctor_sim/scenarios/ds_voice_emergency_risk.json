{
  "schema_version": 2,
  "id": "ds_voice_emergency_risk",
  "scenario_type": "doctor_chat",
  "title": "Voice emergency style risk alert",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "陈秀英",
    "gender": "女",
    "age": 72
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "陈秀英，女，72岁。她刚才打电话说她现在胸痛持续30分钟不缓解，大汗淋漓。她住在幸福小区3号楼。需要立即处理！"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "陈秀英"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
