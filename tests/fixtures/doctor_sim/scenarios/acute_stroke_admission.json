{
  "schema_version": 2,
  "id": "acute_stroke_admission",
  "scenario_type": "doctor_chat",
  "title": "Compound create-save: acute stroke admission",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "刘丽萍",
    "gender": "男",
    "age": 81
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者刘丽萍，男81岁，卒中单元。突发左侧肢体无力并言语不清5小时，NIHSS 6分，头颅MRI示右侧基底节急性梗死，阿司匹林100mg qd，阿托伐他汀40mg qn。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "刘丽萍"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.intake_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
