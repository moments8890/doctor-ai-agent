{
  "schema_version": 2,
  "id": "direct_save_no_confirm",
  "scenario_type": "doctor_chat",
  "title": "Compound create + record: direct save with clinical content",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "王芳"
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者王芳，胸痛3天"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "王芳"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
