{
  "schema_version": 2,
  "id": "ds_cardiology_new_intake",
  "scenario_type": "doctor_chat",
  "title": "Cardiology new intake",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "张明",
    "gender": "男",
    "age": 56
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "新患者，张明，男，56岁。主诉胸痛3天，每次持续5-10分钟，活动后加重，休息缓解。有高血压病史10年，吸烟30年，每天1包。需要做心电图和心肌酶。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "张明"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.interview_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
