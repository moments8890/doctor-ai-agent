{
  "schema_version": 2,
  "id": "oncology_breast_her2",
  "scenario_type": "doctor_chat",
  "title": "Specialty: oncology breast cancer HER2 targeted therapy",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "周慧",
    "gender": "女",
    "age": 52
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者周慧，女52岁，肿瘤科。左乳浸润性导管癌T2N1M0，ER+/PR+/HER2 3+，Ki-67 40%，已行AC-TH方案化疗第4周期，今日曲妥珠单抗维持治疗。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "周慧"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.intake_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
