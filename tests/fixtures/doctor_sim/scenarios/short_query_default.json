{
  "schema_version": 2,
  "id": "short_query_default",
  "scenario_type": "doctor_chat",
  "title": "Edge case: short query '查' defaults to context patient",
  "tags": [
    "regression",
    "edge_case"
  ],
  "patient": {
    "name": "周宁",
    "gender": "女",
    "age": 48
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者周宁，女48岁，高血压3年，今日血压142/88。"
      },
      {
        "actor": "doctor",
        "text": "查"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "周宁"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.intake_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
