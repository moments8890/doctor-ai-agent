{
  "schema_version": 2,
  "id": "special_chars_parens",
  "scenario_type": "doctor_chat",
  "title": "Edge case: special chars — parentheses around patient name",
  "tags": [
    "regression",
    "edge_case"
  ],
  "patient": {
    "name": "张三"
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "记录患者（张三）头痛2天，伴恶心呕吐，无发热"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "张三"
      }
    ]
  }
}
