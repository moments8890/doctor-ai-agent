{
  "schema_version": 2,
  "id": "ds_cardiology_followup",
  "scenario_type": "doctor_chat",
  "title": "Cardiology follow-up existing patient",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "李淑芳",
    "gender": "女",
    "age": 68
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "患者李淑芳，女，68岁，昨天复查结果：血压135/85，心电图正常，血脂：LDL 2.8。目前服用阿托伐他汀20mg daily，无不适。继续当前治疗，3个月复查。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "李淑芳"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.interview_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
