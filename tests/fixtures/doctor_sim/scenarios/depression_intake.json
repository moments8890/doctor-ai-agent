{
  "schema_version": 2,
  "id": "depression_intake",
  "scenario_type": "doctor_chat",
  "title": "Compound create-save: depression intake",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "陈雪宁",
    "gender": "女",
    "age": 34
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者陈雪宁，女34岁，心理门诊。情绪低落2月，早醒，注意力下降，PHQ-9 17分，GAD-7 11分，否认自杀计划，拟舍曲林50mg qd并安排2周复诊。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "陈雪宁"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.intake_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
