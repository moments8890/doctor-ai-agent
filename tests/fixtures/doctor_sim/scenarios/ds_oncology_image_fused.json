{
  "schema_version": 2,
  "id": "ds_oncology_image_fused",
  "scenario_type": "doctor_chat",
  "title": "Oncology image-based (fused text)",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "王建国",
    "gender": "男",
    "age": 62
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "王建国，男，62岁，肺癌术后3个月。这是今天CT报告文字：右肺下叶术后改变，未见明确肿块或淋巴结肿大，胸腔无积液。患者主诉轻度咳嗽，无痰。继续观察。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "王建国"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.interview_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
