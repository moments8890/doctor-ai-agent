{
  "schema_version": 2,
  "id": "neurology_ich_gcs_nihss",
  "scenario_type": "doctor_chat",
  "title": "Specialty: neurology ICH with GCS and NIHSS",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "李四"
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "记录李四脑出血 GCS 8分 术后NIHSS 12分"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "李四"
      }
    ]
  }
}
