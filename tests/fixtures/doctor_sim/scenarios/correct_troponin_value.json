{
  "schema_version": 2,
  "id": "correct_troponin_value",
  "scenario_type": "doctor_chat",
  "title": "Create then correct latest record: troponin correction",
  "tags": [
    "regression",
    "update_record"
  ],
  "patient": {
    "name": "林秋月",
    "gender": "女",
    "age": 67
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者林秋月，女67岁，心内监护。胸闷伴气促，hs-cTnT 0.038 ng/mL，BNP 1220 pg/mL，双下肢轻度水肿，呋塞米40mg iv。"
      },
      {
        "actor": "doctor",
        "text": "更正林秋月刚才那条病历：肌钙蛋白不是0.038，是0.033。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "林秋月"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.interview_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
