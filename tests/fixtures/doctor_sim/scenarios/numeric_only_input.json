{
  "schema_version": 2,
  "id": "numeric_only_input",
  "scenario_type": "doctor_chat",
  "title": "Edge case: numeric-only input should not crash",
  "tags": [
    "regression",
    "edge_case"
  ],
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "12345"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.count",
        "matcher": "max",
        "expected": 0
      },
      {
        "target": "db.medical_records.count",
        "matcher": "max",
        "expected": 0
      }
    ]
  }
}
