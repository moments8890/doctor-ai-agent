{
  "schema_version": 2,
  "id": "schedule_followup",
  "scenario_type": "doctor_chat",
  "title": "Schedule follow-up for existing patient",
  "tags": [
    "regression",
    "schedule"
  ],
  "patient": {
    "name": "杨志明",
    "gender": "男",
    "age": 55
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者杨志明，男55岁，心内门诊。冠心病PCI术后随访，血压正常，血脂达标。"
      },
      {
        "actor": "doctor",
        "text": "给杨志明安排三个月后复查心电图"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "杨志明"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.interview_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
