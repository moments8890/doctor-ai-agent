{
  "schema_version": 2,
  "id": "general_medicine_uri",
  "scenario_type": "doctor_chat",
  "title": "Specialty: general medicine URI with fever",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "王五",
    "gender": "男",
    "age": 35
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者王五，男35岁，门诊。上呼吸道感染，发热38.5℃，咽充血，白细胞正常，予对症处理。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "王五"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.intake_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
