{
  "schema_version": 2,
  "id": "endocrine_dka_emergency",
  "scenario_type": "doctor_chat",
  "title": "Specialty: endocrine DKA emergency with lab values",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "赵敏",
    "gender": "女",
    "age": 29
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者赵敏，女29岁，急诊。1型糖尿病DKA，血糖28.6 mmol/L，血酮5.2 mmol/L，pH 7.18，HCO3- 8 mmol/L，予胰岛素泵持续静滴及补液。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "赵敏"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.interview_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
