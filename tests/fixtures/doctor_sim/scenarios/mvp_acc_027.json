{
  "case_id": "MVP-ACC-027",
  "title": "Query only: no write side effects",
  "group": "query_only",
  "chatlog": [
    {
      "speaker": "doctor",
      "text": "创建患者张三，男45岁，内科门诊。高血压病史3年，BP 145/92。",
      "assert": {
        "tools_include": [
          "create_record"
        ],
        "llm_calls": 3
      }
    },
    {
      "speaker": "doctor",
      "text": "确认",
      "assert": {
        "tools_include": [],
        "llm_calls": 0
      }
    },
    {
      "speaker": "doctor",
      "text": "查张三最近病历",
      "assert": {
        "tools_include": [
          "query_records"
        ],
        "llm_calls": 2
      }
    }
  ],
  "expectations": {
    "must_not_timeout": true,
    "expected_patient_name": "张三",
    "expected_patient_count": 1,
    "expect_patient_dedup": true,
    "expected_table_min_counts_by_doctor": {
      "patients": 1,
      "medical_records": 1
    },
    "expected_table_max_counts_by_doctor": {
      "medical_records": 1
    }
  }
}
