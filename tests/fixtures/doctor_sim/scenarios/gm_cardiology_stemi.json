{
  "schema_version": 2,
  "id": "gm_cardiology_stemi",
  "scenario_type": "doctor_chat",
  "title": "Cardiology STEMI intake",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "张建国",
    "gender": "男",
    "age": 65
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "帮我录入一个新病人，张建国，男，65岁。心前区压榨性疼痛持续2小时，伴大汗。心电图显示ST段抬高，初步诊断急性下壁心肌梗死。给阿司匹林300mg负荷量，准备紧急做PCI。下午提醒我查心肌酶。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "张建国"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.interview_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
