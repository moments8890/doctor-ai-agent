{
  "schema_version": 2,
  "id": "cardiology_followup_query",
  "scenario_type": "doctor_chat",
  "title": "Create then query history: cardiology follow-up",
  "tags": [
    "regression",
    "query_history"
  ],
  "patient": {
    "name": "王丽",
    "gender": "女",
    "age": 62
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者王丽，女62岁，心内门诊。既往HFpEF，今晨端坐呼吸，BP 158/96，HR 112，SpO2 89%，BNP 1860 pg/mL，呋塞米40mg iv。"
      },
      {
        "actor": "doctor",
        "text": "查王丽刚才那条记录"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "王丽"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.intake_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
