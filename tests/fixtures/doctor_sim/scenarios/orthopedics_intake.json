{
  "schema_version": 2,
  "id": "orthopedics_intake",
  "scenario_type": "doctor_chat",
  "title": "Compound create-save: orthopedics (non-cardiology specialty)",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "刘志强",
    "gender": "男",
    "age": 65
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者刘志强，男65岁，骨科门诊。腰椎间盘突出L4/5复发，左下肢放射痛VAS 7分，直腿抬高试验阳性，MRI示椎间盘突出压迫左侧神经根。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "刘志强"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.intake_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
