{
  "schema_version": 2,
  "id": "nephrology_ckd_egfr",
  "scenario_type": "doctor_chat",
  "title": "Specialty: nephrology CKD with eGFR and proteinuria",
  "tags": [
    "regression",
    "create_save"
  ],
  "patient": {
    "name": "李建国",
    "gender": "男",
    "age": 68
  },
  "input": {
    "mode": "doctor_chat",
    "turns": [
      {
        "actor": "doctor",
        "text": "创建患者李建国，男68岁，肾内科门诊。CKD G4期，eGFR 22 mL/min/1.73m2，24h尿蛋白3.2g，Scr 268 μmol/L，K+ 5.6 mmol/L，限钾饮食并调整降压方案。"
      }
    ]
  },
  "execution": {
    "entrypoint": "records.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "db.patients.name",
        "matcher": "eq",
        "expected": "李建国"
      },
      {
        "target": "db.patients.count",
        "matcher": "eq",
        "expected": 1
      },
      {
        "target": "db.patients.count",
        "matcher": "min",
        "expected": 1
      },
      {
        "target": "db.interview_sessions.count",
        "matcher": "min",
        "expected": 1
      }
    ]
  }
}
