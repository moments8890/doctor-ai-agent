{
  "schema_version": 2,
  "id": "registration_links_doctor_patient",
  "scenario_type": "patient_intake",
  "title": "Registration links to doctor-created patient",
  "tags": [
    "regression",
    "registration"
  ],
  "pre_create_patient": {
    "name": "已有王芳",
    "gender": "女",
    "year_of_birth": 1988
  },
  "register_input": {
    "name": "已有王芳",
    "gender": "女",
    "year_of_birth": 1988,
    "phone": "13800000007"
  },
  "input": {
    "mode": "patient_intake"
  },
  "execution": {
    "entrypoint": "patient.intake.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "registration.links_existing",
        "matcher": "eq",
        "expected": true
      },
      {
        "target": "registration.backfills_phone",
        "matcher": "eq",
        "expected": true
      },
      {
        "target": "registration.no_duplicate",
        "matcher": "eq",
        "expected": true
      }
    ]
  }
}
