{
  "schema_version": 2,
  "id": "history_injection_rare_allergy",
  "scenario_type": "patient_interview",
  "title": "History injection — confirms rare allergy and past conditions by name",
  "tags": [
    "regression",
    "history_injection"
  ],
  "patient": {
    "name": "测试历史注入",
    "gender": "女",
    "age": 42,
    "phone": "13800000011"
  },
  "prior_record": {
    "content": "主诉：腰痛1周。既往糖尿病5年，服用二甲双胍。磺胺类药物过敏。母亲有类风湿。",
    "structured": {
      "chief_complaint": "腰痛1周",
      "past_history": "糖尿病5年，服用二甲双胍",
      "allergy_history": "磺胺类药物过敏",
      "family_history": "母亲有类风湿",
      "personal_history": "不吸烟，不饮酒"
    }
  },
  "input": {
    "mode": "patient_interview",
    "turns": [
      {
        "actor": "patient",
        "text": "膝盖疼"
      },
      {
        "actor": "patient",
        "text": "一周了，走路时候加重"
      },
      {
        "actor": "patient",
        "text": "糖尿病还在吃药"
      },
      {
        "actor": "patient",
        "text": "过敏的药还是一样"
      },
      {
        "actor": "patient",
        "text": "家里人没什么变化"
      },
      {
        "actor": "patient",
        "text": "还是不抽烟不喝酒"
      }
    ]
  },
  "execution": {
    "entrypoint": "patient.interview.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "interview.fields_filled",
        "matcher": "min",
        "expected": 4
      },
      {
        "target": "interview.field.chief_complaint",
        "matcher": "present",
        "expected": true
      },
      {
        "target": "interview.field.present_illness",
        "matcher": "present",
        "expected": true
      },
      {
        "target": "interview.field.allergy_history",
        "matcher": "present",
        "expected": true
      },
      {
        "target": "interview.field.chief_complaint",
        "matcher": "contains_any",
        "expected": [
          "膝盖"
        ]
      },
      {
        "target": "interview.field.allergy_history",
        "matcher": "contains_any",
        "expected": [
          "磺胺"
        ]
      },
      {
        "target": "interview.history_leveraged",
        "matcher": "eq",
        "expected": true
      },
      {
        "target": "interview.replies",
        "matcher": "mentions_all",
        "expected": [
          "磺胺",
          "糖尿病",
          "类风湿"
        ]
      }
    ]
  }
}
