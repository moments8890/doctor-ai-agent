{
  "schema_version": 2,
  "id": "registration_rejects_mismatched_yob",
  "scenario_type": "patient_intake",
  "title": "Registration rejects mismatched YOB",
  "tags": [
    "regression",
    "registration"
  ],
  "pre_create_patient": {
    "name": "冲突李明",
    "gender": "男",
    "year_of_birth": 1975
  },
  "register_input": {
    "name": "冲突李明",
    "gender": "男",
    "year_of_birth": 1990,
    "phone": "13800000008"
  },
  "input": {
    "mode": "patient_intake"
  },
  "execution": {
    "entrypoint": "patient.intake.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "registration.rejected",
        "matcher": "eq",
        "expected": true
      },
      {
        "target": "registration.reject_reason",
        "matcher": "contains",
        "expected": "不符"
      }
    ]
  }
}
