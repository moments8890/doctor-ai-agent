{
  "schema_version": 2,
  "id": "negatives_extraction",
  "scenario_type": "patient_intake",
  "title": "Patient says '没有' to everything — negatives extracted",
  "tags": [
    "regression",
    "negatives"
  ],
  "patient": {
    "name": "测试头晕",
    "gender": "女",
    "age": 26,
    "phone": "13800000004"
  },
  "input": {
    "mode": "patient_intake",
    "turns": [
      {
        "actor": "patient",
        "text": "头晕"
      },
      {
        "actor": "patient",
        "text": "今天开始的，不严重"
      },
      {
        "actor": "patient",
        "text": "以前没有得过什么病"
      },
      {
        "actor": "patient",
        "text": "没有药物过敏"
      },
      {
        "actor": "patient",
        "text": "家人没有类似的病"
      },
      {
        "actor": "patient",
        "text": "不吸烟不喝酒"
      }
    ]
  },
  "execution": {
    "entrypoint": "patient.intake.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "intake.fields_filled",
        "matcher": "min",
        "expected": 5
      },
      {
        "target": "intake.field.chief_complaint",
        "matcher": "present",
        "expected": true
      },
      {
        "target": "intake.field.chief_complaint",
        "matcher": "contains_any",
        "expected": [
          "头晕"
        ]
      },
      {
        "target": "intake.status",
        "matcher": "eq",
        "expected": "reviewing"
      },
      {
        "target": "intake.confirm_creates_record",
        "matcher": "eq",
        "expected": true
      },
      {
        "target": "intake.negative_fields",
        "matcher": "includes_all",
        "expected": [
          "past_history",
          "allergy_history",
          "family_history"
        ]
      }
    ]
  }
}
