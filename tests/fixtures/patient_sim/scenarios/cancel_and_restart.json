{
  "schema_version": 2,
  "id": "cancel_and_restart",
  "scenario_type": "patient_interview",
  "title": "Cancel and restart gives fresh session",
  "tags": [
    "regression",
    "session_management"
  ],
  "patient": {
    "name": "测试取消",
    "gender": "女",
    "age": 31,
    "phone": "13800000006"
  },
  "input": {
    "mode": "patient_interview",
    "turns": [
      {
        "actor": "patient",
        "text": "膝盖疼"
      }
    ]
  },
  "execution": {
    "entrypoint": "patient.interview.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "session.cancel_restart",
        "matcher": "eq",
        "expected": true
      }
    ]
  }
}
