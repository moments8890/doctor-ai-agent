{
  "schema_version": 2,
  "id": "abdominal_pain_surgical_history",
  "scenario_type": "patient_intake",
  "title": "Abdominal pain with surgical history",
  "tags": [
    "regression",
    "full_flow"
  ],
  "patient": {
    "name": "测试腹痛",
    "gender": "女",
    "age": 41,
    "phone": "13800000002"
  },
  "input": {
    "mode": "patient_intake",
    "turns": [
      {
        "actor": "patient",
        "text": "肚子疼"
      },
      {
        "actor": "patient",
        "text": "两天了，阵发性的"
      },
      {
        "actor": "patient",
        "text": "做过阑尾手术"
      },
      {
        "actor": "patient",
        "text": "青霉素过敏"
      },
      {
        "actor": "patient",
        "text": "父亲有糖尿病"
      },
      {
        "actor": "patient",
        "text": "吸烟，不喝酒"
      }
    ]
  },
  "execution": {
    "entrypoint": "patient.intake.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "intake.fields_filled",
        "matcher": "min",
        "expected": 6
      },
      {
        "target": "intake.field.chief_complaint",
        "matcher": "present",
        "expected": true
      },
      {
        "target": "intake.field.present_illness",
        "matcher": "present",
        "expected": true
      },
      {
        "target": "intake.field.past_history",
        "matcher": "present",
        "expected": true
      },
      {
        "target": "intake.field.allergy_history",
        "matcher": "present",
        "expected": true
      },
      {
        "target": "intake.field.chief_complaint",
        "matcher": "contains_any",
        "expected": [
          "肚子疼",
          "腹痛"
        ]
      },
      {
        "target": "intake.field.past_history",
        "matcher": "contains_any",
        "expected": [
          "阑尾",
          "手术"
        ]
      },
      {
        "target": "intake.field.allergy_history",
        "matcher": "contains_any",
        "expected": [
          "青霉素"
        ]
      },
      {
        "target": "intake.status",
        "matcher": "eq",
        "expected": "reviewing"
      },
      {
        "target": "intake.confirm_creates_record",
        "matcher": "eq",
        "expected": true
      },
      {
        "target": "record.type",
        "matcher": "eq",
        "expected": "intake_summary"
      },
      {
        "target": "task.created",
        "matcher": "eq",
        "expected": true
      }
    ]
  }
}
