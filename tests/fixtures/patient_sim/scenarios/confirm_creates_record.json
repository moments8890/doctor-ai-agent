{
  "schema_version": 2,
  "id": "confirm_creates_record",
  "scenario_type": "patient_intake",
  "title": "Confirm creates record visible in patient records API",
  "tags": [
    "regression",
    "handoff"
  ],
  "patient": {
    "name": "测试交接",
    "gender": "男",
    "age": 46,
    "phone": "13800000010"
  },
  "input": {
    "mode": "patient_intake",
    "turns": [
      {
        "actor": "patient",
        "text": "咳嗽一周了"
      },
      {
        "actor": "patient",
        "text": "有痰，黄色的"
      },
      {
        "actor": "patient",
        "text": "没有其他疾病"
      },
      {
        "actor": "patient",
        "text": "没有过敏"
      },
      {
        "actor": "patient",
        "text": "家人没有类似情况"
      },
      {
        "actor": "patient",
        "text": "不抽烟不喝酒"
      }
    ]
  },
  "execution": {
    "entrypoint": "patient.intake.chat",
    "auto_confirm": false,
    "timeout_seconds": 60
  },
  "expectations": {
    "assertions": [
      {
        "target": "intake.confirm_creates_record",
        "matcher": "eq",
        "expected": true
      },
      {
        "target": "task.title",
        "matcher": "contains",
        "expected": "预问诊"
      },
      {
        "target": "record.content",
        "matcher": "contains_any",
        "expected": [
          "咳嗽",
          "痰"
        ]
      },
      {
        "target": "record.visible_in_api",
        "matcher": "eq",
        "expected": true
      }
    ]
  }
}
