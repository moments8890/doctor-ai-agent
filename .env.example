# ── Routing LLM — intent dispatch & function calling (~300 tokens/call) ───────
# Options: ollama | deepseek | groq | gemini
# Defaults to STRUCTURING_LLM if not set.
ROUTING_LLM=ollama

# ── Structuring LLM — medical record JSON generation (~800 tokens/call) ───────
# Options: ollama | deepseek | groq | gemini
STRUCTURING_LLM=ollama

# ── Ollama (local, free) ──────────────────────────────────────────────────────
# Start : ollama serve
# Model : ollama pull qwen2.5:14b  (recommended — best local function calling + extraction)
#         ollama pull qwen2.5:7b  (lighter alternative, ~5 GB RAM)
OLLAMA_BASE_URL=http://192.168.0.123:11434/v1
# Optional separate vision endpoint override (defaults to OLLAMA_BASE_URL)
OLLAMA_VISION_BASE_URL=http://192.168.0.123:11434/v1
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_API_KEY=ollama

# ── DeepSeek (cloud, cheapest paid option) ────────────────────────────────────
# DEEPSEEK_API_KEY=sk-...

# ── Groq (cloud, free tier: 100K tokens/day) ──────────────────────────────────
# GROQ_API_KEY=gsk_...

# ── Gemini (cloud) ─────────────────────────────────────────────────────────────
# GEMINI_API_KEY=...
# Optional vision override for /api/records/from-image:
# GEMINI_VISION_MODEL=gemini-2.0-flash

# ── WeChat KF / WeCom (recommended for local E2E, doctor-openclaw compatible) ─
WECHAT_KF_CORP_ID=
WECHAT_KF_SECRET=
WECHAT_KF_TOKEN=
WECHAT_KF_ENCODING_AES_KEY=
# Optional default open_kfid for proactive/out-of-band sends.
# For direct reply flow, server also tries to derive this from inbound message target.
WECHAT_KF_OPEN_KFID=

# Legacy aliases (optional fallback; server prefers WECHAT_KF_* when both exist)
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=
WECHAT_ENCODING_AES_KEY=

# ── Notification Provider ───────────────────────────────────────────────────
# log (default): local/dev sink, writes to logs/tasks.log; no external dependency
# wechat: send to doctor via WeChat customer service API
# NOTIFICATION_PROVIDER=wechat

# ── Database (SQLite) ────────────────────────────────────────────────────────
# Optional: absolute path to share one DB across multiple local repos.
# Example: /Users/jingwuxu/Documents/code/shared-db/patients.db
# PATIENTS_DB_PATH=

# ── Patient Risk / Timeline Automation (v1) ───────────────────────────────
# Enable automatic follow-up task creation from follow_up_plan after record write.
# AUTO_FOLLOWUP_TASKS_ENABLED=false

# ── Task Logging ────────────────────────────────────────────────────────────
# Keep task scheduler logs out of terminal by default; they still go to logs/tasks.log.
# TASK_LOG_TO_CONSOLE=false
# Keep APScheduler internal executor logs out of terminal by default; they go to logs/scheduler.log.
# SCHEDULER_LOG_TO_CONSOLE=false

# ── Task Notification Retry ─────────────────────────────────────────────────
# Retries for background task notification send failures.
# TASK_NOTIFY_RETRY_COUNT=3
# TASK_NOTIFY_RETRY_DELAY_SECONDS=1

# ── Dev Tools (disabled by default) ─────────────────────────────────────────
# Allow manually triggering one notification cycle via POST /api/tasks/dev/run-notifier.
# TASK_DEV_ENDPOINT_ENABLED=false
