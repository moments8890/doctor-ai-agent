# ── LLM provider for medical record structuring ──────────────────────────────
# Options: ollama | deepseek | groq
LLM_PROVIDER=ollama

# ── Intent detection ──────────────────────────────────────────────────────────
# Options: local (rule-based, default) | ollama | deepseek | groq
INTENT_PROVIDER=local

# ── Ollama (local) ───────────────────────────────────────────────────────────
# Start with: ollama serve
# Pull model: ollama pull qwen2.5:7b
OLLAMA_API_KEY=ollama

# ── DeepSeek (cloud fallback) ─────────────────────────────────────────────────
# DEEPSEEK_API_KEY=sk-...

# ── Groq (cloud fallback) ────────────────────────────────────────────────────
# GROQ_API_KEY=gsk_...

# ── WeChat Official Account ───────────────────────────────────────────────────
WECHAT_TOKEN=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_ENCODING_AES_KEY=
