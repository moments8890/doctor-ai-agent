# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
# Debug output (logs, temp files) but not frontend mock data
/debug/
*.debug

# Environment & secrets
.env
project.config.json
project.private.config.json

# Database
*.db
data/*.db

# Datasette / SQLite temp
*.db-shm
*.db-wal

# Pytest
.pytest_cache/
.coverage
reports/
logs/

# macOS
.DS_Store

# IDE
.idea/
.vscode/
.superpowers/

# Frontend
frontend/**/node_modules/
frontend/.vite/
frontend/**/dist/
frontend/android/
frontend/ios/
frontend/.env.android
frontend/web/android/app/build/

# Playwright artifacts
frontend/web/playwright-report/
frontend/web/test-results/
frontend/web/test-results-archive/
frontend/web/.playwright/

# local screts, runtime config
config/local.secrets
config/runtime.json
config/credentials.local.md
config/*.local.*

# DB snapshots / backups (large binary, never commit)
patients.db.bak.*
*.db.bak.*

# Mined routing rules and turn log (generated artifacts)
data/*.json
logs/turn_log.jsonl

# local training data
train
.env.local
.gstack/
tests/prompts/.env

# Generated QA report artifacts (HTML, screenshots) — not canonical checklists
docs/qa/*-report/
docs/qa/*.html

# Demo simulation state
scripts/.demo_state.json

# Uploaded original files
uploads/

# Ephemeral session state (Claude Code / gstack / Codex)
.claude/scheduled_tasks.lock
.context/
frontend/web/.context/

# Local QA snapshot artifacts (screenshots, videos)
docs/ux/screenshots/snap-*/
test-results/

# GlitchTip secrets (per-host, never committed)
deploy/tencent/glitchtip/glitchtip.secrets
deploy/tencent/glitchtip/postgres_data/

# Internal wiki docs are DERIVED from source .md files via
# scripts/sync-internal-wiki-docs.sh — committing them duplicates
# content and creates drift. The sync runs:
#   prod:  deploy.sh before vite build
#   local: predev/prebuild hooks in frontend/web/package.json
frontend/web/public/wiki/internal-docs/
